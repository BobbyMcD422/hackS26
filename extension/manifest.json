{
  "manifest_version": 3,
  "name": "MyMarist ICS Generator",
  "version": "1.0.0",
  "description": "Turns Your Registration Info Into An ICS File, Downloadable To Any iCal Platform!",
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://my.marist.edu/*"],
      "js": ["lib/luxon.min.js", "content.js"]
    }
  ]
}